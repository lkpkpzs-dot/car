/* 启动页容器 */
.splash-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

/* 背景层 */
.background-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* 渐变背景 */
.gradient-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #050816 0%, #0a1628 40%, #0b1736 70%, #0f172a 100%);
}

/* 城市天际线 */
.city-skyline {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 40%;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 20rpx;
  padding: 0 50rpx;
}

.building {
  background: linear-gradient(180deg, rgba(59, 130, 246, 0.15) 0%, rgba(37, 99, 235, 0.3) 50%, rgba(30, 64, 175, 0.2) 100%);
  border: 1px solid rgba(147, 197, 253, 0.3);
  border-bottom: none;
  position: relative;
}

.building::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: 
    linear-gradient(to bottom, transparent 50%, rgba(96, 165, 250, 0.1) 50%),
    linear-gradient(to right, transparent 50%, rgba(96, 165, 250, 0.1) 50%);
  background-size: 20rpx 20rpx;
  opacity: 0.5;
}

.building-1 {
  width: 40rpx;
  height: 200rpx;
  border-top-left-radius: 10rpx;
  border-top-right-radius: 10rpx;
}

.building-2 {
  width: 60rpx;
  height: 280rpx;
  border-top-left-radius: 15rpx;
  border-top-right-radius: 15rpx;
}

.building-3 {
  width: 50rpx;
  height: 350rpx;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
}

.building-4 {
  width: 70rpx;
  height: 260rpx;
  border-top-left-radius: 12rpx;
  border-top-right-radius: 12rpx;
}

.building-5 {
  width: 45rpx;
  height: 220rpx;
  border-top-left-radius: 8rpx;
  border-top-right-radius: 8rpx;
}

/* 发光道路网络 */
.road-network {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.road {
  position: absolute;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(59, 130, 246, 0.4) 20%, 
    rgba(96, 165, 250, 0.6) 50%, 
    rgba(59, 130, 246, 0.4) 80%, 
    transparent 100%);
  box-shadow: 0 0 20rpx rgba(96, 165, 250, 0.5), 0 0 40rpx rgba(59, 130, 246, 0.3);
}

.road-1 {
  top: 50%;
  left: -10%;
  width: 120%;
  height: 4rpx;
  transform: rotate(-15deg);
  animation: road-pulse 3s ease-in-out infinite;
}

.road-2 {
  top: 40%;
  left: -10%;
  width: 120%;
  height: 3rpx;
  transform: rotate(10deg);
  animation: road-pulse 3s ease-in-out infinite 0.5s;
}

.road-3 {
  top: 60%;
  left: -10%;
  width: 120%;
  height: 3rpx;
  transform: rotate(5deg);
  animation: road-pulse 3s ease-in-out infinite 1s;
}

.road-4 {
  top: 30%;
  left: -10%;
  width: 120%;
  height: 2rpx;
  transform: rotate(-8deg);
  animation: road-pulse 3s ease-in-out infinite 1.5s;
}

@keyframes road-pulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.8; }
}

/* 连接节点 */
.connectivity-nodes {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.node {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(96, 165, 250, 1) 0%, rgba(59, 130, 246, 0.5) 50%, transparent 70%);
  box-shadow: 0 0 30rpx rgba(96, 165, 250, 0.8), 0 0 60rpx rgba(59, 130, 246, 0.4);
  animation: node-pulse 2s ease-in-out infinite;
}

.node-1 {
  top: 25%;
  left: 15%;
  animation-delay: 0s;
}

.node-2 {
  top: 35%;
  right: 20%;
  animation-delay: 0.4s;
}

.node-3 {
  top: 55%;
  left: 25%;
  animation-delay: 0.8s;
}

.node-4 {
  top: 45%;
  right: 30%;
  animation-delay: 1.2s;
}

.node-5 {
  top: 65%;
  left: 50%;
  animation-delay: 1.6s;
}

@keyframes node-pulse {
  0%, 100% { 
    transform: scale(0.8);
    opacity: 0.6;
  }
  50% { 
    transform: scale(1.2);
    opacity: 1;
  }
}

/* 光尾动画 */
.light-trails {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.trail {
  position: absolute;
  height: 3rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(147, 197, 253, 0.8) 20%, rgba(96, 165, 250, 1) 50%, rgba(59, 130, 246, 0.8) 80%, transparent 100%);
  box-shadow: 0 0 20rpx rgba(96, 165, 250, 0.6);
  border-radius: 2rpx;
}

.trail-1 {
  top: 45%;
  left: -50%;
  width: 40%;
  animation: trail-move-1 4s linear infinite;
}

.trail-2 {
  top: 52%;
  left: -60%;
  width: 35%;
  animation: trail-move-2 3.5s linear infinite 0.5s;
}

.trail-3 {
  top: 38%;
  left: -45%;
  width: 30%;
  animation: trail-move-3 4.5s linear infinite 1s;
}

@keyframes trail-move-1 {
  0% { left: -50%; }
  100% { left: 150%; }
}

@keyframes trail-move-2 {
  0% { left: -60%; }
  100% { left: 140%; }
}

@keyframes trail-move-3 {
  0% { left: -45%; }
  100% { left: 155%; }
}

/* 前景层 */
.foreground-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 10;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 200rpx 0 120rpx;
  box-sizing: border-box;
}

/* Logo区域 */
.logo-section {
  display: flex;
  justify-content: center;
  align-items: center;
  flex: 1;
}

.logo-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
}

.logo-icon {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.car-shape {
  position: relative;
  width: 160rpx;
  height: 80rpx;
}

.car-body {
  position: absolute;
  width: 140rpx;
  height: 50rpx;
  background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 50%, #2563eb 100%);
  border-radius: 60rpx 80rpx 40rpx 40rpx;
  top: 10rpx;
  left: 10rpx;
  box-shadow: 0 10rpx 30rpx rgba(59, 130, 246, 0.5);
}

.car-body::before {
  content: '';
  position: absolute;
  top: -15rpx;
  left: 30rpx;
  width: 60rpx;
  height: 30rpx;
  background: linear-gradient(135deg, rgba(96, 165, 250, 0.6) 0%, rgba(59, 130, 246, 0.4) 100%);
  border-radius: 20rpx 40rpx 0 0;
  border: 2rpx solid rgba(147, 197, 253, 0.5);
}

.car-wheel {
  position: absolute;
  width: 30rpx;
  height: 30rpx;
  background: radial-gradient(circle, #1e293b 30%, #334155 70%);
  border-radius: 50%;
  border: 3rpx solid #60a5fa;
  box-shadow: 0 0 10rpx rgba(96, 165, 250, 0.5);
}

.wheel-1 {
  bottom: 5rpx;
  left: 25rpx;
}

.wheel-2 {
  bottom: 5rpx;
  right: 25rpx;
}

.car-glow {
  position: absolute;
  bottom: -10rpx;
  left: 0;
  width: 160rpx;
  height: 20rpx;
  background: radial-gradient(ellipse, rgba(59, 130, 246, 0.4) 0%, transparent 70%);
  border-radius: 50%;
}

.logo-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.main-text {
  font-size: 64rpx;
  font-weight: 800;
  letter-spacing: 8rpx;
  color: #ffffff;
  text-shadow: 
    0 0 20rpx rgba(96, 165, 250, 0.8),
    0 0 40rpx rgba(59, 130, 246, 0.6),
    0 0 60rpx rgba(37, 99, 235, 0.4);
  background: linear-gradient(135deg, #93c5fd 0%, #60a5fa 50%, #3b82f6 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.sub-text {
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
  color: rgba(147, 197, 253, 0.7);
}

/* 加载区域 */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 0 80rpx;
}

.loading-bar-container {
  width: 100%;
  height: 8rpx;
  background: rgba(15, 23, 42, 0.8);
  border-radius: 10rpx;
  border: 1rpx solid rgba(30, 64, 175, 0.3);
  overflow: hidden;
  position: relative;
}

.loading-bar-container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent 0%, rgba(96, 165, 250, 0.1) 50%, transparent 100%);
  animation: shimmer 2s linear infinite;
}

@keyframes shimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

.loading-bar {
  height: 100%;
  background: linear-gradient(90deg, #3b82f6 0%, #60a5fa 50%, #93c5fd 100%);
  border-radius: 10rpx;
  position: relative;
  transition: width 0.1s linear;
}

.loading-bar-glow {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 100%;
  background: radial-gradient(ellipse, rgba(147, 197, 253, 0.8) 0%, transparent 70%);
}

.loading-text {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(147, 197, 253, 0.9);
  letter-spacing: 2rpx;
}
