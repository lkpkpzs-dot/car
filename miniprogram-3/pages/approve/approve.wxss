page {
  background: #f0f4f8;
  min-height: 100vh;
}

.audit-container {
  min-height: 100vh;
}

.header-section {
  background: linear-gradient(135deg, #1a365d 0%, #2c5282 100%);
  padding: 40rpx 30rpx;
  text-align: center;
  color: white;
}

.page-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.page-subtitle {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
}

.tab-section {
  background: white;
  padding: 0 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab-bar {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.tab-item {
  position: relative;
  padding: 30rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.tab-text {
  font-size: 28rpx;
  color: #666;
}

.tab-item.active .tab-text {
  color: #3182ce;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #3182ce;
  border-radius: 3rpx;
}

.tab-badge {
  background: #e53e3e;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

.list-section {
  height: calc(100vh - 240rpx);
  padding: 20rpx;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.task-card:active {
  transform: scale(0.98);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.task-type {
  background: rgba(49, 130, 206, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.type-text {
  font-size: 22rpx;
  color: #3182ce;
  font-weight: 500;
}

.task-status {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.task-status text {
  font-size: 22rpx;
  font-weight: 500;
}

.task-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #1a365d;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.task-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.task-time {
  font-size: 24rpx;
  color: #999;
}

.task-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.modal-content {
  width: 100%;
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a365d;
}

.close-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-text {
  font-size: 48rpx;
  color: #999;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx;
}

.detail-section {
  margin-bottom: 30rpx;
}

.detail-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #1a365d;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #3182ce;
}

.detail-info {
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.history-list {
  padding-left: 20rpx;
}

.history-item {
  position: relative;
  padding-left: 30rpx;
  padding-bottom: 30rpx;
}

.history-item:last-child {
  padding-bottom: 0;
}

.history-item:last-child .history-line {
  display: none;
}

.history-line {
  position: absolute;
  left: 9rpx;
  top: 24rpx;
  bottom: 0;
  width: 2rpx;
  background: #e2e8f0;
}

.history-dot {
  position: absolute;
  left: 0;
  top: 8rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 4rpx solid white;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.history-content {
  padding-left: 20rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.history-node {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a365d;
}

.history-action {
  font-size: 24rpx;
  font-weight: 500;
}

.history-comment {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.history-time {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

.reject-btn {
  background: #fff5f5;
  color: #e53e3e;
}

.approve-btn {
  background: linear-gradient(135deg, #3182ce 0%, #2c5282 100%);
  color: white;
}

.btn-text {
  color: inherit;
  font-weight: bold;
}
