page {
  background: #f4f7fb;
  min-height: 100vh;
}

.admin-container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header-section {
  background: linear-gradient(135deg, #10233f 0%, #1b4a7d 58%, #2f7ec7 100%);
  padding: 72rpx 32rpx;
  color: #ffffff;
  position: relative;
  overflow: hidden;
}

.header-section::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 340rpx;
  height: 340rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.header-section::after {
  content: '';
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 0;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.24);
}

.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
  gap: 16rpx;
}

.role-badge,
.logout-btn {
  border-radius: 999rpx;
  backdrop-filter: blur(10rpx);
}

.role-badge {
  background: rgba(255, 255, 255, 0.16);
  padding: 10rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.badge-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 600;
}

.logout-btn {
  padding: 10rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.34);
  background: rgba(255, 255, 255, 0.12);
}

.logout-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

.greeting {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.25;
  position: relative;
  z-index: 1;
}

.stats-section {
  padding: 0 32rpx;
  margin-top: -44rpx;
  position: relative;
  z-index: 10;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.stat-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 28rpx 26rpx;
  text-align: left;
  box-shadow: 0 10rpx 28rpx rgba(20, 55, 95, 0.1);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  transition: all 0.25s;
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  bottom: 0;
  width: 8rpx;
}

.stat-pending::before {
  background: #d97706;
}

.stat-approved::before {
  background: #16a34a;
}

.stat-rejected::before {
  background: #dc2626;
}

.stat-today::before {
  background: #2563eb;
}

.stat-card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 22rpx rgba(20, 55, 95, 0.12);
}

.stat-value {
  display: block;
  font-size: 46rpx;
  font-weight: 800;
  color: #132238;
  line-height: 1.1;
  margin-top: 4rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #697586;
  margin-top: 10rpx;
  font-weight: 600;
}

.actions-section {
  padding: 42rpx 32rpx 34rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #132238;
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 36rpx;
  background: #2563eb;
  border-radius: 4rpx;
}

.view-all {
  font-size: 26rpx;
  color: #2563eb;
  font-weight: 600;
}

.actions-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.action-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 34rpx 24rpx;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(20, 55, 95, 0.07);
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  transition: all 0.25s;
  position: relative;
  overflow: hidden;
}

.action-card::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(37, 99, 235, 0.04);
  opacity: 0;
  transition: opacity 0.25s;
}

.action-card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 22rpx rgba(20, 55, 95, 0.1);
}

.action-card:active::before {
  opacity: 1;
}

.action-icon {
  width: 88rpx;
  height: 88rpx;
  margin: 0 auto 18rpx;
  background: #eef5ff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.action-icon image {
  width: 52rpx;
  height: 52rpx;
}

.action-name {
  display: block;
  font-size: 29rpx;
  font-weight: 700;
  color: #132238;
  margin-bottom: 8rpx;
  position: relative;
  z-index: 1;
}

.action-desc {
  display: block;
  font-size: 24rpx;
  color: #697586;
  line-height: 1.4;
  position: relative;
  z-index: 1;
}

.unread-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: #ef4444;
  border-radius: 999rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.3);
  z-index: 2;
}

.unread-text {
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 700;
  line-height: 1;
}

.recent-section {
  padding: 0 32rpx;
}

.recent-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(20, 55, 95, 0.07);
  border: 1rpx solid rgba(148, 163, 184, 0.14);
}

.recent-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #eef2f7;
  transition: background 0.2s;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-item:active {
  background: #f8fafc;
}

.item-info {
  flex: 1;
  min-width: 0;
  margin-right: 20rpx;
}

.item-name {
  display: block;
  font-size: 29rpx;
  font-weight: 700;
  color: #132238;
  margin-bottom: 8rpx;
}

.item-company {
  display: block;
  font-size: 24rpx;
  color: #697586;
}

.item-status {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.item-status text {
  font-size: 22rpx;
  font-weight: 600;
}
