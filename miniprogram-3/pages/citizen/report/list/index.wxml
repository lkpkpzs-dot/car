<view class="page">
  <view class="header">
    <text class="title">我的举报</text>
    <text class="subtitle">查看提交记录和处理结果</text>
  </view>

  <view class="tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="*this"
      class="tab {{currentTab === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="onTabChange"
    >
      <text>{{item}}</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="state">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <view wx:elif="{{list.length === 0}}" class="state empty">
    <image src="/assets/images/empty.png" mode="aspectFit" />
    <text>{{currentTab === 0 ? '暂无举报记录' : '暂无该状态记录'}}</text>
  </view>

  <view wx:else class="list">
    <view wx:for="{{list}}" wx:for-index="reportIndex" wx:key="reportId" class="report-card">
      <view class="card-header">
        <view class="type-badge">{{item.reportTypeName}}</view>
        <view class="tags">
          <text class="risk-tag risk-{{item.riskClass}}" wx:if="{{item.riskLabel}}">{{item.riskLabel}}</text>
          <view class="status-badge status-{{item.statusClass}}">{{item.statusLabel}}</view>
        </view>
      </view>

      <view class="info-list">
        <view class="info-row" wx:if="{{item.targetPlate}}">
          <text class="label">车牌号码</text>
          <text class="value plate">{{item.targetPlate}}</text>
        </view>
        <view class="info-row">
          <text class="label">举报地点</text>
          <text class="value">{{item.locationText || '未填写'}}</text>
        </view>
        <view class="info-row">
          <text class="label">举报时间</text>
          <text class="value">{{item.createTimeText}}</text>
        </view>
        <view class="info-row" wx:if="{{item.reviewTime}}">
          <text class="label">审核时间</text>
          <text class="value">{{item.reviewTime}}</text>
        </view>
        <view class="info-row remark" wx:if="{{item.reviewRemark}}">
          <text class="label">审核备注</text>
          <text class="value">{{item.reviewRemark}}</text>
        </view>
      </view>

      <view class="image-row" wx:if="{{item.images.length > 0}}">
        <image
          wx:for="{{item.images}}"
          wx:for-item="image"
          wx:for-index="imageIndex"
          wx:key="*this"
          class="thumb"
          src="{{image}}"
          mode="aspectFill"
          data-index="{{reportIndex}}"
          data-image-index="{{imageIndex}}"
          bindtap="onPreviewImage"
        />
      </view>
    </view>
  </view>
</view>
