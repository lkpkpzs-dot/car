.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.state {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #dbe4ef;
  border-top-color: #1a365d;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.state-text {
  font-size: 28rpx;
  color: #86909c;
}

.empty-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #e5e7eb;
  color: #86909c;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.message-panel,
.section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 28rpx rgba(26, 54, 93, 0.06);
}

.message-top {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.message-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: #e8f2ff;
  color: #1a365d;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.message-meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.message-title {
  font-size: 38rpx;
  line-height: 1.35;
  color: #172033;
  font-weight: 700;
}

.message-time {
  font-size: 24rpx;
  color: #8b97a8;
}

.message-body {
  display: block;
  font-size: 30rpx;
  line-height: 1.75;
  color: #3f4a5f;
  word-break: break-all;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 32rpx;
  color: #172033;
  font-weight: 700;
}

.section-count {
  font-size: 26rpx;
  color: #8b97a8;
}

.status-badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

.status-0 {
  background: #fff7e6;
  color: #b46b00;
}

.status-1 {
  background: #e8f7ee;
  color: #178347;
}

.status-2 {
  background: #fff0f0;
  color: #c73535;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.info-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 28rpx;
}

.info-label {
  width: 180rpx;
  flex-shrink: 0;
  color: #7d8797;
  font-size: 28rpx;
  line-height: 1.5;
}

.info-value {
  flex: 1;
  min-width: 0;
  color: #1f2937;
  font-size: 28rpx;
  line-height: 1.5;
  text-align: right;
  word-break: break-all;
}

.info-value.plate {
  color: #1a365d;
  font-size: 32rpx;
  font-weight: 700;
}

.info-item.remark {
  padding-top: 4rpx;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.image-card {
  width: 100%;
  aspect-ratio: 1;
  overflow: hidden;
  border-radius: 12rpx;
  background: #eef2f7;
}

.evidence-image {
  width: 100%;
  height: 100%;
}
