<view class="page" wx:if="{{detail}}">
  <view class="form-card card">
    <view class="detail-header">
      <text class="section-title">基础信息</text>
      <status-tag label="{{detail.statusLabel}}" color="{{detail.statusColor}}" bgColor="{{detail.statusBg}}" />
    </view>
    <view class="info-row"><text class="info-label">姓名</text><text class="info-value">{{detail.officerName}}</text></view>
    <view class="info-row"><text class="info-label">身份证号</text><text class="info-value">{{detail.idCardNo}}</text></view>
    <view class="info-row"><text class="info-label">手机号</text><text class="info-value">{{detail.phone || '-'}}</text></view>
    <view class="info-row"><text class="info-label">年龄</text><text class="info-value">{{detail.age || '-'}}</text></view>
    <view class="info-row"><text class="info-label">驾驶证类型</text><text class="info-value">{{detail.licenseType || '-'}}</text></view>
    <view class="info-row"><text class="info-label">驾驶证号</text><text class="info-value">{{detail.driverLicenseNo || '-'}}</text></view>
    <view class="info-row"><text class="info-label">初次领证日期</text><text class="info-value">{{detail.firstLicenseDate || '-'}}</text></view>
    <view class="info-row"><text class="info-label">审核意见</text><text class="info-value">{{detail.auditCommentText}}</text></view>
    <view class="info-row"><text class="info-label">暂停起止日期</text><text class="info-value">{{detail.suspendRangeText}}</text></view>
    <view class="info-row"><text class="info-label">处分原因</text><text class="info-value">{{detail.penaltyReasonText}}</text></view>
  </view>

  <view class="form-card card" wx:if="{{detail.materialList.length > 0}}">
    <text class="section-title">材料预览</text>
    <view class="material-grid">
      <view class="material-item" wx:for="{{detail.materialList}}" wx:key="key">
        <text class="material-label">{{item.label}}</text>
        <image class="material-img" src="{{item.url}}" mode="aspectFill" data-url="{{item.url}}" bindtap="previewImage" />
      </view>
    </view>
  </view>

  <view class="form-card card">
    <text class="section-title">处分记录</text>
    <view class="empty-line" wx:if="{{penalties.length === 0}}">暂无处分记录</view>
    <view class="penalty-item" wx:for="{{penalties}}" wx:key="penaltyId">
      <view class="penalty-title">{{item.accidentDate || item.createTime}}</view>
      <view class="penalty-line">责任等级：{{item.liabilityLabel || '-'}}</view>
      <view class="penalty-line">伤亡情况：{{item.casualtyLabel || '-'}}</view>
      <view class="penalty-line">处分原因：{{item.reason || item.penaltyReason || '-'}}</view>
    </view>
  </view>

  <view class="footer-actions">
    <button class="plain-btn" wx:if="{{detail.status === 0 || detail.status === 2}}" bindtap="onDelete">删除记录</button>
    <button class="plain-btn disabled" wx:else disabled>删除记录</button>
    <button class="submit-btn" wx:if="{{detail.status === 2}}" bindtap="goResubmit">重新提交</button>
  </view>
</view>
