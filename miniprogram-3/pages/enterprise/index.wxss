@import "./enterprise.wxss";

.header {
  background: linear-gradient(135deg, #0e2d3b 0%, #16606b 58%, #2a9d8f 100%);
  padding: 64rpx 32rpx 88rpx;
  color: #ffffff;
  position: relative;
  overflow: hidden;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.message-btn {
  position: relative;
  width: 68rpx;
  height: 68rpx;
  background: rgba(255, 255, 255, 0.16);
  border-radius: 50%;
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.message-icon {
  font-size: 34rpx;
  line-height: 1;
}

.message-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #ef4444;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
  border: 3rpx solid #2a9d8f;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 32rpx;
}

.header::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -120rpx;
  width: 360rpx;
  height: 360rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 50%;
}

.header-left {
  flex: 1;
  position: relative;
  z-index: 1;
}

.header-title {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.25;
  position: relative;
  z-index: 1;
}

.header-sub {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 12rpx;
  position: relative;
  z-index: 1;
  font-weight: 500;
}

.refresh-btn {
  padding: 12rpx 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 999rpx;
  backdrop-filter: blur(10rpx);
  position: relative;
  z-index: 1;
}

.refresh-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
}

.status-card {
  margin: -56rpx 32rpx 0;
  position: relative;
  z-index: 10;
  box-shadow: 0 8rpx 24rpx rgba(16, 80, 88, 0.08);
  border: 1rpx solid rgba(42, 157, 143, 0.12);
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
}

.company-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #102a36;
}

.company-tip {
  display: block;
  font-size: 24rpx;
  color: #697586;
  margin-top: 10rpx;
  font-weight: 500;
}

.stats-card {
  margin: 32rpx;
  display: flex;
  align-items: center;
  border-radius: 16rpx;
  padding: 30rpx 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(16, 80, 88, 0.08);
  border: 1rpx solid rgba(42, 157, 143, 0.12);
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
  border-radius: 12rpx;
  transition: all 0.25s;
  position: relative;
  overflow: hidden;
}

.stat-item:active {
  transform: scale(0.95);
  background: rgba(42, 157, 143, 0.08);
}

.stat-item::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 4rpx;
  width: 28rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: rgba(42, 157, 143, 0.24);
  transform: translateX(-50%);
}

.stat-num {
  display: block;
  font-size: 46rpx;
  font-weight: 800;
  color: #102a36;
  line-height: 1.1;
}

.stat-num.stat-blue {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-num.stat-green {
  background: linear-gradient(135deg, #0f9f86, #047867);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-num.stat-warn {
  background: linear-gradient(135deg, #f59e0b, #d97706);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #697586;
  margin-top: 12rpx;
  font-weight: 600;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: linear-gradient(180deg, transparent, #e2e8f0, transparent);
}

.section {
  padding: 0 32rpx 48rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #102a36;
  margin-bottom: 24rpx;
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 36rpx;
  background: #0f9f86;
  border-radius: 4rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.action-item {
  padding: 34rpx 24rpx;
  text-align: center;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(16, 80, 88, 0.07);
  border: 1rpx solid rgba(42, 157, 143, 0.12);
  transition: all 0.25s;
  position: relative;
  overflow: hidden;
}

.action-item::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(42, 157, 143, 0.05);
  opacity: 0;
  transition: opacity 0.25s;
}

.action-item:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 22rpx rgba(16, 80, 88, 0.1);
}

.action-item:active::before {
  opacity: 1;
}

.action-icon-wrap {
  width: 86rpx;
  height: 86rpx;
  margin: 0 auto 18rpx;
  background: #e8f7f4;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.action-icon-wrap image {
  width: 52rpx;
  height: 52rpx;
}

.action-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: #ef4444;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  border: 3rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.3);
}

.action-badge-text {
  font-size: 20rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
}

.action-name {
  display: block;
  font-size: 29rpx;
  font-weight: 700;
  color: #102a36;
  position: relative;
  z-index: 1;
  margin-bottom: 8rpx;
}

.action-desc {
  display: block;
  font-size: 24rpx;
  color: #697586;
  margin-top: 10rpx;
  line-height: 1.4;
  position: relative;
  z-index: 1;
  font-weight: 500;
}
