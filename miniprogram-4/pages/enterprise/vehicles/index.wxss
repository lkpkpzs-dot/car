page {
  background: #f8fafc;
  min-height: 100vh;
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header-section {
  background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 50%, #3b82f6 100%);
  padding: 60rpx 32rpx 80rpx;
  color: white;
  position: relative;
  overflow: hidden;
}

.header-section::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -120rpx;
  width: 360rpx;
  height: 360rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.header-content {
  position: relative;
  z-index: 1;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
  font-weight: 500;
}

.list-container {
  padding: 32rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 10;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 160rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
  margin-bottom: 24rpx;
}

.empty-state text {
  font-size: 28rpx;
  color: #64748b;
  font-weight: 500;
}

.vehicle-card {
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  transition: all 0.3s;
}

.vehicle-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.12);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.vehicle-info {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.plate-number {
  font-size: 44rpx;
  font-weight: 800;
  color: #0f172a;
  background: linear-gradient(135deg, #06b6d4, #0891b2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.vehicle-name {
  font-size: 28rpx;
  color: #475569;
  font-weight: 600;
}

.badge {
  font-size: 22rpx;
  color: #059669;
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.1), rgba(5, 150, 105, 0.1));
  padding: 8rpx 20rpx;
  border-radius: 50rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.card-body {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  margin-bottom: 16rpx;
  align-items: center;
}

.info-row:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 26rpx;
  color: #64748b;
  font-weight: 500;
  width: 160rpx;
  flex-shrink: 0;
}

.value {
  font-size: 26rpx;
  color: #1e293b;
  font-weight: 500;
  flex: 1;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  padding-top: 20rpx;
  border-top: 2rpx dashed #e2e8f0;
}

.view-detail {
  font-size: 24rpx;
  color: #3b82f6;
  font-weight: 600;
}
