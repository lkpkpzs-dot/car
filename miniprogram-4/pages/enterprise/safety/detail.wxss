@import "../enterprise.wxss";

.page {
  padding-bottom: 160rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
  font-size: 27rpx;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 190rpx;
  color: #64748b;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  color: #1e293b;
  text-align: right;
  word-break: break-all;
}

.material-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.material-label {
  display: block;
  font-size: 24rpx;
  color: #475569;
  margin-bottom: 10rpx;
}

.material-img {
  width: 100%;
  height: 180rpx;
  border-radius: 12rpx;
  background: #f8fafc;
}

.empty-line {
  font-size: 26rpx;
  color: #94a3b8;
  text-align: center;
  padding: 32rpx 0;
}

.penalty-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.penalty-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a365d;
  margin-bottom: 12rpx;
}

.penalty-line {
  font-size: 25rpx;
  color: #64748b;
  line-height: 1.7;
}

.footer-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.plain-btn,
.submit-btn {
  flex: 1;
}

.plain-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  color: #dc2626;
  background: #fff5f5;
  border: 1rpx solid #fecaca;
  font-size: 30rpx;
}
