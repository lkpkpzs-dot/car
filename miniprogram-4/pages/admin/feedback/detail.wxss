.feedback-detail-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 20rpx 24rpx 40rpx;
}

.detail-section {
  background: white;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.detail-title {
  flex: 1;
  margin-right: 16rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.4;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.status-pending {
  background: #f3f4f6;
}

.status-pending text {
  color: #6b7280;
  font-size: 24rpx;
  font-weight: 500;
}

.status-processing {
  background: #fef3c7;
}

.status-processing text {
  color: #d97706;
  font-size: 24rpx;
  font-weight: 500;
}

.status-approved {
  background: #dcfce7;
}

.status-approved text {
  color: #16a34a;
  font-size: 24rpx;
  font-weight: 500;
}

.detail-meta {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.meta-item {
  display: flex;
  align-items: center;
}

.meta-label {
  font-size: 26rpx;
  color: #9ca3af;
  width: 140rpx;
  flex-shrink: 0;
}

.meta-value {
  font-size: 26rpx;
  color: #4b5563;
  flex: 1;
  font-weight: 500;
}

.detail-content {
  margin-bottom: 24rpx;
}

.content-label {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.content-text {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.8;
}

.detail-images {
  margin-top: 24rpx;
}

.images-label {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
}

.images-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.image-item {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.handle-record {
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.record-remark {
  margin-bottom: 16rpx;
}

.remark-label {
  display: block;
  font-size: 26rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}

.remark-text {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.8;
}

.record-time {
  padding-top: 16rpx;
  border-top: 1rpx solid #e5e7eb;
}

.time-label {
  display: block;
  font-size: 26rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}

.time-text {
  font-size: 26rpx;
  color: #6b7280;
}

.action-section {
  background: white;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.action-content {
  padding-top: 8rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #4b5563;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
  border: 1rpx solid #e5e7eb;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
  color: white;
}

.btn-primary[disabled] {
  background: #d1d5db;
}

.btn-secondary {
  background: white;
  color: #3b82f6;
  border: 2rpx solid #3b82f6;
}

.btn-secondary[disabled] {
  opacity: 0.5;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f4f6;
  border-top: 4rpx solid #3b82f6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  color: #9ca3af;
  font-size: 28rpx;
}
