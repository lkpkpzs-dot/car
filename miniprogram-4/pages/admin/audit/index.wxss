.audit-container {
  min-height: 100vh;
  background-color: #f8fafc;
  display: flex;
  flex-direction: column;
}

.tab-header {
  display: flex;
  background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%);
  padding: 0 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.1);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 32rpx 0;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.tab-item.active {
  color: white;
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  right: 25%;
  height: 8rpx;
  background: linear-gradient(90deg, #60a5fa, #a78bfa);
  border-radius: 4rpx 4rpx 0 0;
}

.tab-badge {
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 10rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #0f172a;
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  border-radius: 50rpx;
  box-shadow: 0 2rpx 8rpx rgba(251, 191, 36, 0.3);
}

.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx 0;
  background: #f8fafc;
}

.filter-chip {
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  color: #64748b;
  background: white;
  border-radius: 50rpx;
  border: 2rpx solid #e2e8f0;
  font-weight: 500;
  transition: all 0.3s;
}

.filter-chip.active {
  color: #1e40af;
  background: linear-gradient(135deg, #dbeafe, #e0e7ff);
  border-color: #3b82f6;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.15);
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  background: white;
  border-radius: 50rpx;
  border: 2rpx solid #e2e8f0;
  transition: all 0.3s;
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.04);
}

.search-input:focus {
  border-color: #3b82f6;
  box-shadow: 0 0 0 6rpx rgba(59, 130, 246, 0.1);
}

.search-clear {
  font-size: 26rpx;
  color: #3b82f6;
  flex-shrink: 0;
  font-weight: 500;
  padding: 8rpx 16rpx;
  background: rgba(59, 130, 246, 0.1);
  border-radius: 16rpx;
}

.list-section {
  flex: 1;
  padding: 0 32rpx 32rpx;
  box-sizing: border-box;
  height: calc(100vh - 340rpx);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-state text:last-child {
  font-size: 28rpx;
  color: #94a3b8;
  font-weight: 500;
}

.audit-card {
  background: white;
  border-radius: 28rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.audit-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.12);
}

.audit-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: linear-gradient(180deg, #3b82f6, #8b5cf6);
  opacity: 0;
  transition: opacity 0.3s;
}

.audit-card:active::before {
  opacity: 1;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.title-group {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.business-type-tag {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 50rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.type-license {
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
  color: #1e40af;
  border: none;
}

.type-enterprise {
  background: linear-gradient(135deg, #ccfbf1, #99f6e4);
  color: #0f766e;
  border: none;
}

.task-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: 0.3rpx;
}

.status-tag {
  font-size: 22rpx;
  padding: 10rpx 24rpx;
  border-radius: 50rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
  font-weight: 600;
  letter-spacing: 0.3rpx;
}

.status-tag.pending {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  color: #92400e;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(245, 158, 11, 0.2);
}

.status-tag.processed {
  background: linear-gradient(135deg, #dcfce7, #bbf7d0);
  color: #166534;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(34, 197, 94, 0.2);
}

.card-body {
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  align-items: center;
}

.label {
  color: #64748b;
  width: 160rpx;
  font-weight: 500;
}

.value {
  color: #334155;
  flex: 1;
  font-weight: 500;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 2rpx dashed #e2e8f0;
}

.detail-hint {
  font-size: 26rpx;
  color: #3b82f6;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.arrow {
  font-size: 32rpx;
  color: #3b82f6;
  font-weight: bold;
}
