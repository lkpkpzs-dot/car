.feedback-list-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 20rpx 32rpx;
}

.list-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feedback-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.05);
  transition: all 0.25s;
}

.feedback-card:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.08);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.card-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.4;
  margin-right: 16rpx;
}

.card-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.card-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-type {
  font-size: 26rpx;
  color: #6b7280;
  font-weight: 500;
}

.card-time {
  font-size: 24rpx;
  color: #9ca3af;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #9ca3af;
}
