.uploader-item {
  margin-bottom: 32rpx;
}

.uploader-label {
  display: block;
  font-size: 28rpx;
  color: #334155;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.uploader-box {
  height: 220rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border: 3rpx dashed #cbd5e1;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.uploader-box:active {
  background: #e2e8f0;
  border-color: #94a3b8;
  transform: scale(0.98);
}

.uploader-plus {
  font-size: 56rpx;
  color: #64748b;
  line-height: 1;
  font-weight: 300;
}

.uploader-hint {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 12rpx;
  font-weight: 500;
}

.uploader-preview {
  position: relative;
}

.preview-img {
  width: 100%;
  height: 220rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.08);
  border: 2rpx solid #e2e8f0;
}

.preview-actions {
  display: flex;
  gap: 32rpx;
  margin-top: 16rpx;
}

.action-btn {
  font-size: 26rpx;
  color: #2563eb;
  font-weight: 500;
  padding: 8rpx 20rpx;
  background: rgba(37, 99, 235, 0.1);
  border-radius: 12rpx;
}

.action-btn.danger {
  color: #dc2626;
  background: rgba(220, 38, 38, 0.1);
}
