page {
  background: #fffbeb;
  min-height: 100vh;
}

.citizen-container {
  min-height: 100vh;
  padding-bottom: 30rpx;
}

.header-section {
  background: linear-gradient(135deg, #ed8936 0%, #f6ad55 100%);
  padding: 60rpx 30rpx 40rpx;
  color: white;
}

.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.role-badge {
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.badge-text {
  font-size: 22rpx;
  color: white;
}

.logout-btn {
  padding: 8rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 20rpx;
}

.logout-text {
  font-size: 24rpx;
  color: white;
}

.greeting {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.greeting-desc {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
}

.stats-section {
  padding: 0 30rpx;
  margin-top: -30rpx;
}

.qualification-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.qual-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.qual-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #92400e;
}

.stats-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stats-header {
  margin-bottom: 20rpx;
}

.stats-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #92400e;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #92400e;
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: #666;
  margin-top: 4rpx;
}

.actions-section {
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #92400e;
  padding-left: 16rpx;
  border-left: 6rpx solid #f59e0b;
}

.actions-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.action-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.action-card:active {
  transform: scale(0.98);
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto 16rpx;
  background: rgba(245, 158, 11, 0.1);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon image {
  width: 50rpx;
  height: 50rpx;
}

.action-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #92400e;
  margin-bottom: 8rpx;
}

.action-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.tips-section {
  padding: 0 30rpx;
}

.tips-list {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tip-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tip-item:last-child {
  border-bottom: none;
}

.tip-icon {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.icon-text {
  font-size: 24rpx;
  font-weight: bold;
  color: white;
}

.tip-content {
  flex: 1;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #92400e;
  margin-bottom: 8rpx;
}

.tip-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.footer-section {
  text-align: center;
  padding: 40rpx 30rpx;
  margin-top: 30rpx;
  background: rgba(245, 158, 11, 0.1);
  border-radius: 16rpx;
}

.footer-text {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #92400e;
  margin-bottom: 8rpx;
}

.footer-sub {
  display: block;
  font-size: 24rpx;
  color: #b45309;
}
