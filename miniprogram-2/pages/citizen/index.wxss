page {
  background: #fffbeb;
  min-height: 100vh;
}

.citizen-container {
  min-height: 100vh;
  padding-bottom: 30rpx;
}

.header-section {
  background: linear-gradient(135deg, #ea580c 0%, #f97316 50%, #fb923c 100%);
  padding: 70rpx 32rpx 50rpx;
  color: white;
  position: relative;
  overflow: hidden;
}

.header-section::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -120rpx;
  width: 360rpx;
  height: 360rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.message-btn {
  position: relative;
  padding: 12rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  backdrop-filter: blur(10rpx);
}

.message-icon {
  font-size: 36rpx;
  line-height: 1;
}

.message-badge {
  position: absolute;
  top: 0;
  right: 0;
  min-width: 32rpx;
  height: 32rpx;
  background: #ef4444;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
  border: 3rpx solid #ea580c;
}

.message-badge text {
  font-size: 20rpx;
  color: white;
  font-weight: 700;
  line-height: 1;
}

.role-badge {
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  padding: 10rpx 24rpx;
  border-radius: 50rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.25);
}

.badge-text {
  font-size: 22rpx;
  color: white;
  font-weight: 600;
}

.logout-btn {
  padding: 10rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  border-radius: 50rpx;
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(10rpx);
}

.logout-text {
  font-size: 24rpx;
  color: white;
  font-weight: 500;
}

.greeting {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
  position: relative;
  z-index: 1;
  letter-spacing: 0.5rpx;
}

.greeting-desc {
  display: block;
  font-size: 26rpx;
  opacity: 0.95;
  position: relative;
  z-index: 1;
  font-weight: 500;
}

.stats-section {
  padding: 0 32rpx;
  margin-top: -36rpx;
  position: relative;
  z-index: 10;
}

.qualification-card {
  background: white;
  border-radius: 28rpx;
  padding: 32rpx 36rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(234, 88, 12, 0.1);
  border: 1rpx solid rgba(251, 146, 60, 0.12);
}

.qual-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.qual-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #92400e;
}

.stats-card {
  background: white;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(234, 88, 12, 0.08);
  border: 1rpx solid rgba(251, 146, 60, 0.12);
}

.stats-header {
  margin-bottom: 24rpx;
}

.stats-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #92400e;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.stat-item {
  text-align: center;
  padding: 16rpx 8rpx;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: linear-gradient(135deg, #92400e, #b45309);
  background: linear-gradient(135deg, #92400e, #b45309);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  line-height: 1.1;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #78716c;
  margin-top: 8rpx;
  font-weight: 500;
}

.actions-section {
  padding: 40rpx 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #92400e;
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(180deg, #f59e0b, #ea580c);
  border-radius: 4rpx;
}

.actions-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.action-card {
  background: white;
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 24rpx rgba(234, 88, 12, 0.06);
  border: 1rpx solid rgba(251, 146, 60, 0.1);
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.action-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.04), rgba(251, 146, 60, 0.04));
  opacity: 0;
  transition: opacity 0.3s;
}

.action-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(234, 88, 12, 0.12);
}

.action-card:active::before {
  opacity: 1;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 20rpx;
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.12), rgba(251, 146, 60, 0.12));
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.action-icon image {
  width: 56rpx;
  height: 56rpx;
}

.action-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #92400e;
  margin-bottom: 10rpx;
  position: relative;
  z-index: 1;
}

.action-desc {
  display: block;
  font-size: 24rpx;
  color: #78716c;
  line-height: 1.4;
  position: relative;
  z-index: 1;
  font-weight: 500;
}

.tips-section {
  padding: 0 32rpx;
}

.tips-list {
  background: white;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(234, 88, 12, 0.06);
  border: 1rpx solid rgba(251, 146, 60, 0.1);
}

.tip-item {
  display: flex;
  align-items: flex-start;
  padding: 32rpx;
  border-bottom: 2rpx solid #fef3c7;
  transition: background 0.2s;
}

.tip-item:last-child {
  border-bottom: none;
}

.tip-item:active {
  background: #fffbeb;
}

.tip-icon {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.25);
}

.icon-text {
  font-size: 26rpx;
  font-weight: 800;
  color: white;
}

.tip-content {
  flex: 1;
}

.tip-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #92400e;
  margin-bottom: 10rpx;
}

.tip-desc {
  display: block;
  font-size: 26rpx;
  color: #78716c;
  line-height: 1.6;
  font-weight: 500;
}

.footer-section {
  text-align: center;
  padding: 48rpx 32rpx;
  margin-top: 32rpx;
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.1), rgba(251, 146, 60, 0.1));
  border-radius: 28rpx;
  border: 2rpx dashed rgba(245, 158, 11, 0.25);
}

.footer-text {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #92400e;
  margin-bottom: 10rpx;
}

.footer-sub {
  display: block;
  font-size: 26rpx;
  color: #b45309;
  font-weight: 500;
}
