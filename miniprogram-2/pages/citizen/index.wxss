page {
  background: #fff7ed;
  min-height: 100vh;
}

.citizen-container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header-section {
  background: linear-gradient(135deg, #9a3412 0%, #ea580c 56%, #f59e0b 100%);
  padding: 72rpx 32rpx 66rpx;
  color: #ffffff;
  position: relative;
  overflow: hidden;
}

.header-section::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -120rpx;
  width: 360rpx;
  height: 360rpx;
  background: rgba(255, 255, 255, 0.14);
  border-radius: 50%;
}

.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
  gap: 16rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.message-btn {
  position: relative;
  width: 68rpx;
  height: 68rpx;
  background: rgba(255, 255, 255, 0.16);
  border-radius: 50%;
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.message-icon {
  font-size: 34rpx;
  line-height: 1;
}

.message-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #ef4444;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
  border: 3rpx solid #ea580c;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 32rpx;
}

.role-badge {
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(10rpx);
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.badge-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 600;
}

.logout-btn {
  padding: 10rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(10rpx);
}

.logout-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

.greeting {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.25;
  margin-bottom: 10rpx;
  position: relative;
  z-index: 1;
}

.greeting-desc {
  display: block;
  font-size: 26rpx;
  opacity: 0.95;
  position: relative;
  z-index: 1;
  font-weight: 500;
}

.stats-section {
  padding: 0 32rpx;
  margin-top: -42rpx;
  position: relative;
  z-index: 10;
}

.qualification-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 30rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(154, 52, 18, 0.09);
  border: 1rpx solid rgba(251, 146, 60, 0.16);
}

.qual-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.qual-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #92400e;
}

.stats-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(154, 52, 18, 0.08);
  border: 1rpx solid rgba(251, 146, 60, 0.16);
}

.stats-header {
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.stats-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #92400e;
}

.view-all {
  font-size: 24rpx;
  color: #ea580c;
  font-weight: 600;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.stat-item {
  text-align: left;
  padding: 22rpx 24rpx;
  border-radius: 14rpx;
  background: #fff7ed;
  border: 1rpx solid rgba(251, 146, 60, 0.18);
  transition: all 0.2s;
  position: relative;
}

.stat-item:active {
  background: #ffedd5;
  transform: scale(0.98);
}

.stat-value {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #92400e, #c2410c);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  line-height: 1.1;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #78716c;
  margin-top: 8rpx;
  font-weight: 600;
}

.actions-section {
  padding: 42rpx 32rpx 34rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #92400e;
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 36rpx;
  background: #ea580c;
  border-radius: 4rpx;
}

.actions-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
}

.action-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 34rpx 24rpx;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(154, 52, 18, 0.07);
  border: 1rpx solid rgba(251, 146, 60, 0.16);
  transition: all 0.25s;
  position: relative;
  overflow: hidden;
}

.action-card::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(234, 88, 12, 0.04);
  opacity: 0;
  transition: opacity 0.25s;
}

.action-card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 22rpx rgba(154, 52, 18, 0.1);
}

.action-card:active::before {
  opacity: 1;
}

.action-icon {
  width: 86rpx;
  height: 86rpx;
  margin: 0 auto 18rpx;
  background: #fff1df;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.action-icon image {
  width: 52rpx;
  height: 52rpx;
}

.action-name {
  display: block;
  font-size: 29rpx;
  font-weight: 700;
  color: #92400e;
  margin-bottom: 8rpx;
  position: relative;
  z-index: 1;
}

.action-desc {
  display: block;
  font-size: 24rpx;
  color: #78716c;
  line-height: 1.4;
  position: relative;
  z-index: 1;
  font-weight: 500;
}

.tips-section {
  padding: 0 32rpx;
}

.tips-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(154, 52, 18, 0.07);
  border: 1rpx solid rgba(251, 146, 60, 0.16);
}

.tip-item {
  display: flex;
  align-items: flex-start;
  padding: 28rpx;
  border-bottom: 1rpx solid #fed7aa;
  transition: background 0.2s;
}

.tip-item:last-child {
  border-bottom: none;
}

.tip-item:active {
  background: #fff7ed;
}

.tip-icon {
  width: 52rpx;
  height: 52rpx;
  background: #ea580c;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(234, 88, 12, 0.25);
}

.icon-text {
  font-size: 25rpx;
  font-weight: 800;
  color: #ffffff;
}

.tip-content {
  flex: 1;
  min-width: 0;
}

.tip-title {
  display: block;
  font-size: 29rpx;
  font-weight: 700;
  color: #92400e;
  margin-bottom: 10rpx;
}

.tip-desc {
  display: block;
  font-size: 26rpx;
  color: #78716c;
  line-height: 1.6;
  font-weight: 500;
}

.footer-section {
  text-align: center;
  padding: 40rpx 32rpx;
  margin: 32rpx 32rpx 0;
  background: rgba(255, 247, 237, 0.85);
  border-radius: 16rpx;
  border: 2rpx dashed rgba(245, 158, 11, 0.28);
}

.footer-text {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #92400e;
  margin-bottom: 10rpx;
}

.footer-sub {
  display: block;
  font-size: 26rpx;
  color: #b45309;
  font-weight: 500;
}
