<view class="feedback-list-container">
  <view class="list-section" wx:if="{{!empty && list.length > 0}}">
    <view 
      wx:for="{{list}}" 
      wx:key="feedbackId" 
      class="feedback-card"
      data-id="{{item.feedbackId}}"
      bindtap="onGoToDetail"
    >
      <view class="card-header">
        <view class="card-title">{{item.title}}</view>
        <view class="card-status" style="color: {{getStatusConfig(item.status).color}}; background: {{getStatusConfig(item.status).bgColor}};">
          {{getStatusConfig(item.status).text}}
        </view>
      </view>
      
      <view class="card-content">
        <view class="card-type">{{getTypeText(item.type)}}</view>
        <view class="card-time">{{item.createTime}}</view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{empty && !loading}}">
    <text class="empty-icon">📝</text>
    <text class="empty-text">暂无反馈记录</text>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
