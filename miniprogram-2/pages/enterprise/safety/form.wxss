@import "../enterprise.wxss";

.page {
  padding-bottom: 160rpx;
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.switch-row:last-child {
  border-bottom: none;
}

.switch-label {
  flex: 1;
  font-size: 27rpx;
  line-height: 1.5;
  color: #475569;
}
