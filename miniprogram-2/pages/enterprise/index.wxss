@import "./enterprise.wxss";

.header {
  background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 50%, #3b82f6 100%);
  padding: 60rpx 32rpx 90rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -120rpx;
  width: 360rpx;
  height: 360rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.12) 0%, transparent 70%);
  border-radius: 50%;
}

.header-title {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  position: relative;
  z-index: 1;
  letter-spacing: 0.5rpx;
}

.header-sub {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 12rpx;
  position: relative;
  z-index: 1;
  font-weight: 500;
}

.status-card {
  margin: -56rpx 32rpx 0;
  position: relative;
  z-index: 10;
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.company-name {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.company-tip {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-top: 10rpx;
  font-weight: 500;
}

.stats-card {
  margin: 32rpx;
  display: flex;
  align-items: center;
  border-radius: 28rpx;
  padding: 36rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.stat-item:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.05), rgba(139, 92, 246, 0.05));
}

.stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.1;
}

.stat-num.stat-blue {
  background: linear-gradient(135deg, #3b82f6, #1e40af);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-num.stat-green {
  background: linear-gradient(135deg, #10b981, #059669);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-num.stat-warn {
  background: linear-gradient(135deg, #f59e0b, #d97706);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-label {
  display: block;
  font-size: 26rpx;
  color: #64748b;
  margin-top: 12rpx;
  font-weight: 500;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: linear-gradient(180deg, transparent, #e2e8f0, transparent);
}

.section {
  padding: 0 32rpx 48rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 24rpx;
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(180deg, #3b82f6, #8b5cf6);
  border-radius: 4rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.action-item {
  padding: 40rpx 32rpx;
  text-align: center;
  border-radius: 28rpx;
  background: white;
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.action-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.03), rgba(139, 92, 246, 0.03));
  opacity: 0;
  transition: opacity 0.3s;
}

.action-item:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.12);
}

.action-item:active::before {
  opacity: 1;
}

.action-icon-wrap {
  width: 90rpx;
  height: 90rpx;
  margin: 0 auto 20rpx;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(139, 92, 246, 0.1));
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.action-icon-wrap image {
  width: 52rpx;
  height: 52rpx;
}

.action-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  position: relative;
  z-index: 1;
  margin-bottom: 10rpx;
}

.action-desc {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-top: 10rpx;
  line-height: 1.4;
  position: relative;
  z-index: 1;
  font-weight: 500;
}
