@import "../enterprise.wxss";

.page {
  padding-bottom: 160rpx;
  background: #fffbeb; /* 市民端背景色 */
}

.section-title {
  border-left-color: #ed8936; /* 市民端橙色 */
}

.submit-btn {
  background: linear-gradient(135deg, #ed8936 0%, #f6ad55 100%); /* 市民端渐变色 */
  color: #fff;
  border: none;
  width: 100% !important;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-btn {
  background: #94a3b8; /* 返回按钮灰色 */
}

.form-tip {
  display: block;
  font-size: 24rpx;
  color: #92400e; /* 深橙色文字 */
  margin: -12rpx 0 24rpx;
}

.license-preview {
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
}

.empty-license {
  font-size: 26rpx;
  color: #94a3b8;
}
