.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  padding: 0 24rpx 24rpx;
  box-sizing: border-box;
}

.header {
  background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);
  padding: 40rpx 32rpx 60rpx;
  margin: 0 -24rpx 32rpx -24rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  position: relative;
  z-index: 1;
}

.state {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #dbe4ef;
  border-top-color: #3b82f6;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.state-text {
  font-size: 28rpx;
  color: #94a3b8;
}

.empty-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #e5e7eb;
  color: #94a3b8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.message-panel,
.section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
  border: 2rpx solid rgba(241, 245, 249, 0.8);
}

.message-top {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.message-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
  color: #1e40af;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.message-meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.message-title {
  font-size: 38rpx;
  line-height: 1.35;
  color: #1e293b;
  font-weight: 700;
}

.message-time {
  font-size: 24rpx;
  color: #94a3b8;
}

.message-body {
  display: block;
  font-size: 30rpx;
  line-height: 1.75;
  color: #475569;
  word-break: break-all;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 32rpx;
  color: #1e293b;
  font-weight: 700;
}

.section-count {
  font-size: 26rpx;
  color: #94a3b8;
}

.status-badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

.status-0 {
  background: #fff7e6;
  color: #b46b00;
}

.status-1 {
  background: #e0f2fe;
  color: #0369a1;
}

.status-2 {
  background: #dcfce7;
  color: #16a34a;
}

.status-3 {
  background: #fee2e2;
  color: #dc2626;
}

.status-4 {
  background: #f3e8ff;
  color: #7c3aed;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.info-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 28rpx;
}

.info-label {
  width: 180rpx;
  flex-shrink: 0;
  color: #64748b;
  font-size: 28rpx;
  line-height: 1.5;
}

.info-value {
  flex: 1;
  min-width: 0;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1.5;
  text-align: right;
  word-break: break-all;
  font-weight: 500;
}

.info-value.plate {
  color: #1e40af;
  font-size: 32rpx;
  font-weight: 700;
}

.info-item.remark {
  padding-top: 4rpx;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.image-card {
  width: 100%;
  aspect-ratio: 1;
  overflow: hidden;
  border-radius: 16rpx;
  background: #eef2f7;
}

.evidence-image {
  width: 100%;
  height: 100%;
}
