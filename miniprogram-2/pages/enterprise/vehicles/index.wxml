<view class="page">
  <view class="header-section">
    <view class="header-content">
      <text class="page-title">我的车辆</text>
      <text class="page-subtitle">已通过查验的车辆信息</text>
    </view>
  </view>

  <view class="list-container">
    <view class="empty-state" wx:if="{{vehicleList.length === 0}}">
      <image src="/assets/images/empty.png" mode="aspectFit" />
      <text>暂无车辆</text>
    </view>

    <view class="vehicle-card card" wx:for="{{vehicleList}}" wx:key="vehicleId" bindtap="onVehicleDetail" data-vehicle="{{item}}">
      <view class="card-header">
        <view class="vehicle-info">
          <text class="plate-number">{{item.plateNumber}}</text>
          <text class="vehicle-name">{{item.vehicleBrand}}</text>
        </view>
        <view class="badge">
          已上牌
        </view>
      </view>
      
      <view class="card-body">
        <view class="info-row">
          <text class="label">VIN码：</text>
          <text class="value">{{item.vin}}</text>
        </view>
        <view class="info-row">
          <text class="label">号牌类型：</text>
          <text class="value">{{plateTypeMap[item.plateType] || '其他'}}</text>
        </view>
        <view class="info-row">
          <text class="label">发证日期：</text>
          <text class="value">{{item.issueDate}}</text>
        </view>
      </view>

      <view class="card-footer">
        <text class="view-detail">查看详情 ›</text>
      </view>
    </view>
  </view>
</view>
