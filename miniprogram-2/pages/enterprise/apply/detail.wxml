<view class="page" wx:if="{{detail}}">
  <view class="form-card card">
    <view class="detail-header">
      <text class="section-title">申请信息</text>
      <status-tag label="{{statusLabel}}" color="{{statusColor}}" bgColor="{{statusBg}}" />
    </view>
    <view class="info-row">
      <text class="info-label">VIN</text>
      <text class="info-value">{{detail.vin}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">申请类型</text>
      <text class="info-value">{{detail.applyTypeLabel}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">申请时间</text>
      <text class="info-value">{{detail.createTime}}</text>
    </view>
  </view>

  <view class="reject-box" wx:if="{{detail.rejectReason}}">
    <text class="reject-title">驳回原因</text>
    <text class="reject-text">{{detail.rejectReason}}</text>
  </view>

  <view class="form-card card" wx:if="{{detail.uploadList.length > 0}}">
    <text class="section-title">材料预览</text>
    <view class="material-grid">
      <view class="material-item" wx:for="{{detail.uploadList}}" wx:key="key">
        <text class="material-label">{{item.label}}</text>
        <image class="material-img" src="{{item.url}}" mode="aspectFill" data-url="{{item.url}}" bindtap="previewImage" />
      </view>
    </view>
  </view>

  <view class="form-card card">
    <text class="section-title">审批记录</text>
    <approval-timeline records="{{detail.approvalRecords}}" />
  </view>
</view>
