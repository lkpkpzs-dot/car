<view class="page">
  <view class="form-card card">
    <text class="section-title">申请信息</text>

    <view class="form-item">
      <text class="form-label required">VIN（车架号）</text>
      <input class="form-input" placeholder="请输入17位车架号" maxlength="17" value="{{vin}}" bindinput="onInput" />
    </view>

    <view class="form-item">
      <text class="form-label required">申请类型</text>
      <picker mode="selector" range="{{applyTypeOptions}}" range-key="label" bindchange="onTypeChange">
        <view class="form-picker">{{applyTypeLabel}}</view>
      </picker>
    </view>
  </view>

  <view class="form-card card">
    <text class="section-title">上传材料</text>
    <image-uploader
      wx:for="{{uploadFields}}"
      wx:key="key"
      label="{{item.label}}"
      value="{{uploads[item.key]}}"
      data-key="{{item.key}}"
      bind:change="onUploadChange"
    />
  </view>

  <view class="footer-btn">
    <button class="submit-btn" bindtap="onSubmit">提交申请</button>
  </view>
</view>
