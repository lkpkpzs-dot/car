.profile-container {
  min-height: 100vh;
  background: #f0f4f8;
  padding: 0;
  padding-bottom: 60rpx;
}

.user-card {
  background: linear-gradient(135deg, #1a365d 0%, #2c5282 100%);
  padding: 60rpx 32rpx 56rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.user-card::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.avatar-section {
  display: flex;
  align-items: center;   /* 垂直居中 */
  margin-left: -90rpx;
}

.avatar-wrapper {
  margin-right: -80rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.avatar-btn {
  padding: 0;
  margin: 0 -12rpx;
  background: transparent;
  border: none;
  line-height: 1;
  box-shadow: none;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.avatar-guide {
  position: absolute;
  top: -80rpx;
  left: 0;
  white-space: nowrap;
  z-index: 10;
}

.guide-bubble {
  display: inline-block;
  background: linear-gradient(135deg, #fff, #f0f9ff);
  color: #1e40af;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.2);
  animation: pulse-guide 2s ease-in-out infinite;
}

.guide-arrow {
  position: absolute;
  left: 50%;
  bottom: -12rpx;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 14rpx solid #fff;
}

@keyframes pulse-guide {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.2);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
  }
}

.username {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 12rpx;
  letter-spacing: 0.5rpx;
}

.role-tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

.card-block {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(15, 23, 42, 0.06);
}

.block-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #3182ce;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
  font-size: 28rpx;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  color: #64748b;
  width: 180rpx;
  flex-shrink: 0;
}

.info-value {
  color: #1e293b;
  flex: 1;
  text-align: right;
}

.license-thumb {
  width: 160rpx;
  height: 120rpx;
  border-radius: 8rpx;
}

.qual-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.qual-header .block-title {
  margin-bottom: 0;
}

.qual-btn {
  background: #1a365d;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
}

/* SVG菜单样式 */
.menu-section {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(15, 23, 42, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 36rpx 32rpx;
  border-bottom: 1rpx solid #f1f5f9;
  transition: all 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f8fafc;
}

.menu-icon {
  width: 52rpx;
  height: 52rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(139, 92, 246, 0.1));
  border-radius: 14rpx;
  padding: 10rpx;
  box-sizing: border-box;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.menu-arrow {
  font-size: 40rpx;
  color: #cbd5e1;
  font-weight: 300;
}
