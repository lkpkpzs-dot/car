.profile-container {
  min-height: 100vh;
  background: #f0f4f8;
  padding: 24rpx;
  padding-bottom: 60rpx;
}

.user-card {
  background: linear-gradient(135deg, #1a365d 0%, #2c5282 100%);
  padding: 48rpx 32rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.avatar-section {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 24rpx;
}

.username {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.role-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
}

.card-block {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.block-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 20rpx;
  padding-left: 12rpx;
  border-left: 6rpx solid #3182ce;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
  font-size: 28rpx;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  color: #64748b;
  width: 180rpx;
  flex-shrink: 0;
}

.info-value {
  color: #1e293b;
  flex: 1;
  text-align: right;
}

.license-thumb {
  width: 160rpx;
  height: 120rpx;
  border-radius: 8rpx;
}

.qual-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.qual-header .block-title {
  margin-bottom: 0;
}

.qual-btn {
  background: #1a365d;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.logout-btn {
  background: #fff;
  color: #dc2626;
  border: 1rpx solid #fecaca;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-top: 16rpx;
}
