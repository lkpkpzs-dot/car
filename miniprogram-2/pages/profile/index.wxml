<view class="profile-container">
  <view class="user-card">
    <view class="avatar-section">
      <image class="avatar" src="/assets/images/logo.png" mode="aspectFill" />
      <view class="user-info">
        <text class="username">{{userInfo.enterpriseName || userInfo.real_name || '企业用户'}}</text>
        <view class="role-tag" style="background-color: {{roleColor}}">{{roleName}}</view>
      </view>
    </view>
  </view>

  <!-- 企业信息展示：仅在已认证时显示 -->
  <view class="card-block" wx:if="{{isEnterprise}}">
    <text class="block-title">企业信息</text>
    <view class="info-item">
      <text class="info-label">企业名称</text>
      <text class="info-value">{{userInfo.enterpriseName || '—'}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">信用代码</text>
      <text class="info-value">{{userInfo.creditCode || '—'}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">法定代表人</text>
      <text class="info-value">{{userInfo.legalPerson || '—'}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">联系电话</text>
      <text class="info-value">{{userInfo.contactPhone || '—'}}</text>
    </view>
    <view class="info-item" wx:if="{{userInfo.licenseImg}}">
      <text class="info-label">营业执照</text>
      <image class="license-thumb" src="{{userInfo.licenseImg}}" mode="aspectFill" bindtap="previewLicense" />
    </view>
  </view>

  <!-- 资质状态与操作：对普通用户/企业用户始终显示 -->
  <view class="card-block" wx:if="{{role !== 'admin'}}">
    <view class="qual-header">
      <text class="block-title">企业资质</text>
      <status-tag label="{{statusLabel}}" color="{{statusColor}}" bgColor="{{statusBg}}" />
    </view>
    <button wx:if="{{showQualBtn}}" class="qual-btn" bindtap="onQualificationAction">{{qualBtnText}}</button>
  </view>

  <!-- 用户基础信息 -->
  <view class="card-block" wx:if="{{!isEnterprise}}">
    <view class="info-item">
      <text class="info-label">姓名</text>
      <text class="info-value">{{userInfo.real_name || '—'}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">电话</text>
      <text class="info-value">{{userInfo.phone || '—'}}</text>
    </view>
  </view>

  <button class="logout-btn" bindtap="onLogout">退出登录</button>
</view>
