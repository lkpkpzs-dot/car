@import "../../enterprise/enterprise.wxss";

.page {
  background: #f1f5f9;
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 200rpx;
}

.apply-card {
  margin-bottom: 24rpx;
  padding: 30rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.apply-type {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
}

.status-capsule {
  padding: 6rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.status-1 { background: #fef3c7; color: #d97706; } /* 待审核 */
.status-2 { background: #dcfce7; color: #16a34a; } /* 通过 */
.status-3 { background: #fee2e2; color: #dc2626; } /* 已驳回 */

.card-body {
  font-size: 28rpx;
  color: #64748b;
}

.info-row {
  margin-bottom: 12rpx;
  display: flex;
}

.info-row .label {
  width: 150rpx;
  flex-shrink: 0;
}

.info-row .value {
  color: #1e293b;
  font-weight: 500;
}

.card-footer {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx dashed #e2e8f0;
}

.reject-reason {
  background: #fff5f5;
  padding: 16rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.reason-label {
  font-size: 24rpx;
  color: #dc2626;
  font-weight: 600;
}

.reason-text {
  font-size: 24rpx;
  color: #991b1b;
}

.re-apply-btn {
  height: 72rpx;
  line-height: 72rpx;
  background: #1a365d;
  color: #fff;
  font-size: 26rpx;
  border-radius: 36rpx;
  width: 200rpx !important;
  margin: 0 0 0 auto !important;
  padding: 0;
}

.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  background: #1a365d;
  color: #fff;
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 20rpx rgba(26, 54, 93, 0.3);
  z-index: 100;
}

.plus {
  font-size: 40rpx;
  margin-right: 12rpx;
  margin-top: -4rpx;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 600;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  color: #94a3b8;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}
