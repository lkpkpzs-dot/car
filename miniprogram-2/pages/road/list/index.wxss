@import "../../enterprise/enterprise.wxss";

.page {
  background: #f8fafc;
  min-height: 100vh;
  padding-bottom: 200rpx;
}

.header-section {
  background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 50%, #3b82f6 100%);
  padding: 60rpx 32rpx 80rpx;
  color: white;
  position: relative;
  overflow: hidden;
}

.header-section::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -120rpx;
  width: 360rpx;
  height: 360rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.header-content {
  position: relative;
  z-index: 1;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
  font-weight: 500;
}

.tabs-container {
  display: flex;
  background: white;
  padding: 24rpx 32rpx;
  margin-top: -40rpx;
  margin-left: 24rpx;
  margin-right: 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(15, 23, 42, 0.06);
  position: relative;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
  position: relative;
  transition: all 0.3s;
}

.tab-text {
  font-size: 28rpx;
  color: #64748b;
  font-weight: 500;
  transition: all 0.3s;
}

.tab-item.active .tab-text {
  color: #1e40af;
  font-weight: 700;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #3b82f6, #8b5cf6);
  border-radius: 3rpx;
}

.list-container {
  padding: 24rpx;
}

.apply-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  transition: all 0.3s;
}

.apply-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.12);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.apply-type {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.status-capsule {
  padding: 8rpx 24rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.status-1 { background: linear-gradient(135deg, #fef3c7, #fde68a); color: #92400e; } /* 待审核 */
.status-2 { background: linear-gradient(135deg, #dcfce7, #bbf7d0); color: #166534; } /* 已通过 */
.status-3 { background: linear-gradient(135deg, #fee2e2, #fecaca); color: #991b1b; } /* 已驳回 */

.card-body {
  font-size: 28rpx;
  color: #64748b;
}

.info-row {
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-row .label {
  width: 160rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.info-row .value {
  color: #1e293b;
  font-weight: 500;
  flex: 1;
}

.card-footer {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed #e2e8f0;
}

.reject-reason {
  background: linear-gradient(135deg, #fff5f5, #fee2e2);
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.reason-label {
  font-size: 24rpx;
  color: #991b1b;
  font-weight: 600;
  margin-bottom: 8rpx;
  display: block;
}

.reason-text {
  font-size: 26rpx;
  color: #7f1d1d;
  line-height: 1.6;
  font-weight: 500;
}

.re-apply-btn {
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #1e40af, #3b82f6);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 40rpx;
  width: 200rpx !important;
  margin: 0 0 0 auto !important;
  padding: 0;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.fab-btn {
  position: fixed;
  right: 32rpx;
  bottom: 60rpx;
  background: linear-gradient(135deg, #1e40af, #3b82f6);
  color: #fff;
  padding: 24rpx 40rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.35);
  z-index: 100;
}

.plus {
  font-size: 44rpx;
  margin-right: 12rpx;
  margin-top: -4rpx;
  font-weight: 300;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 600;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  color: #94a3b8;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
  opacity: 0.4;
}

.empty-state text {
  font-size: 28rpx;
  font-weight: 500;
}
