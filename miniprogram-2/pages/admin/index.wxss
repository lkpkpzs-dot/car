page {
  background: #f0f4f8;
  min-height: 100vh;
}

.admin-container {
  min-height: 100vh;
  padding-bottom: 30rpx;
}

.header-section {
  background: linear-gradient(135deg, #1a365d 0%, #2c5282 100%);
  padding: 60rpx 30rpx 40rpx;
  color: white;
}

.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.role-badge {
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.badge-text {
  font-size: 22rpx;
  color: white;
}

.logout-btn {
  padding: 8rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 20rpx;
}

.logout-text {
  font-size: 24rpx;
  color: white;
}

.greeting {
  font-size: 32rpx;
  font-weight: bold;
}

.stats-section {
  padding: 0 30rpx;
  margin-top: -30rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.stat-card {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stat-pending {
  border-left: 6rpx solid #d97706;
}

.stat-approved {
  border-left: 6rpx solid #16a34a;
}

.stat-rejected {
  border-left: 6rpx solid #dc2626;
}

.stat-today {
  border-left: 6rpx solid #3b82f6;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #1a365d;
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: #666;
  margin-top: 4rpx;
}

.actions-section {
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a365d;
  padding-left: 16rpx;
  border-left: 6rpx solid #3182ce;
}

.view-all {
  font-size: 26rpx;
  color: #3182ce;
}

.actions-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.action-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.action-card:active {
  transform: scale(0.98);
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto 16rpx;
  background: rgba(49, 130, 206, 0.1);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon image {
  width: 50rpx;
  height: 50rpx;
}

.action-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #1a365d;
  margin-bottom: 8rpx;
}

.action-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.recent-section {
  padding: 0 30rpx;
}

.recent-list {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.recent-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.recent-item:last-child {
  border-bottom: none;
}

.item-info {
  flex: 1;
}

.item-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #1a365d;
  margin-bottom: 6rpx;
}

.item-company {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.item-status {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.item-status text {
  font-size: 22rpx;
  font-weight: bold;
}
