page {
  background: #f8fafc;
  min-height: 100vh;
}

.admin-container {
  min-height: 100vh;
  padding-bottom: 30rpx;
}

.header-section {
  background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 50%, #3b82f6 100%);
  padding: 70rpx 32rpx 50rpx;
  color: white;
  position: relative;
  overflow: hidden;
}

.header-section::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
  gap: 16rpx;
}

.header-avatar {
  flex-shrink: 0;
}

.svg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  padding: 8rpx;
}

.role-badge {
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  padding: 10rpx 24rpx;
  border-radius: 50rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.badge-text {
  font-size: 22rpx;
  color: white;
  font-weight: 600;
}

.logout-btn {
  padding: 10rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
}

.logout-text {
  font-size: 24rpx;
  color: white;
  font-weight: 500;
}

.greeting {
  font-size: 36rpx;
  font-weight: 700;
  position: relative;
  z-index: 1;
  letter-spacing: 0.5rpx;
}

.stats-section {
  padding: 0 32rpx;
  margin-top: -36rpx;
  position: relative;
  z-index: 10;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.stat-card {
  background: white;
  border-radius: 24rpx;
  padding: 28rpx 16rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
}

.stat-pending::before {
  background: linear-gradient(90deg, #f59e0b, #d97706);
}

.stat-approved::before {
  background: linear-gradient(90deg, #22c55e, #16a34a);
}

.stat-rejected::before {
  background: linear-gradient(90deg, #f87171, #dc2626);
}

.stat-today::before {
  background: linear-gradient(90deg, #60a5fa, #3b82f6);
}

.stat-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.12);
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.1;
  margin-top: 8rpx;
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: #64748b;
  margin-top: 8rpx;
  font-weight: 500;
}

.actions-section {
  padding: 40rpx 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  position: relative;
}

.section-title::before {
  content: '';
  position: absolute;
  left: -16rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(180deg, #3b82f6, #8b5cf6);
  border-radius: 4rpx;
}

.view-all {
  font-size: 26rpx;
  color: #3b82f6;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.actions-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.action-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.action-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.03), rgba(139, 92, 246, 0.03));
  opacity: 0;
  transition: opacity 0.3s;
}

.action-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.1);
}

.action-card:active::before {
  opacity: 1;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 20rpx;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(139, 92, 246, 0.1));
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.action-icon image {
  width: 56rpx;
  height: 56rpx;
}

.action-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 10rpx;
  position: relative;
  z-index: 1;
}

.action-desc {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.4;
  position: relative;
  z-index: 1;
}

.recent-section {
  padding: 0 32rpx;
}

.recent-list {
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
}

.recent-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f1f5f9;
  transition: background 0.2s;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-item:active {
  background: #f8fafc;
}

.item-info {
  flex: 1;
}

.item-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 8rpx;
}

.item-company {
  display: block;
  font-size: 24rpx;
  color: #64748b;
}

.item-status {
  padding: 10rpx 24rpx;
  border-radius: 50rpx;
  font-weight: 600;
}

.item-status text {
  font-size: 22rpx;
  font-weight: 600;
}
