.audit-container {
  min-height: 100vh;
  background-color: #f7fafc;
  display: flex;
  flex-direction: column;
}

.tab-header {
  display: flex;
  background: #1a365d;
  padding: 0 40rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.tab-item.active {
  color: white;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 6rpx;
  background: #38b2ac;
  border-radius: 3rpx;
}

.tab-badge {
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  font-size: 20rpx;
  font-weight: bold;
  color: #1a365d;
  background: #fbbf24;
  border-radius: 16rpx;
}

.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 30rpx 0;
  background: #f7fafc;
}

.filter-chip {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #64748b;
  background: white;
  border-radius: 32rpx;
  border: 1rpx solid #e2e8f0;
}

.filter-chip.active {
  color: #1a365d;
  background: #ebf8ff;
  border-color: #90cdf4;
  font-weight: bold;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  background: white;
  border-radius: 36rpx;
  border: 1rpx solid #e2e8f0;
}

.search-clear {
  font-size: 24rpx;
  color: #3182ce;
  flex-shrink: 0;
}

.list-section {
  flex: 1;
  padding: 0 30rpx 30rpx;
  box-sizing: border-box;
  height: calc(100vh - 320rpx);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-state text:last-child {
  font-size: 26rpx;
  color: #a0aec0;
}

.audit-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.audit-card:active {
  transform: scale(0.98);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #edf2f7;
}

.title-group {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.business-type-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.type-license {
  background: #ebf8ff;
  color: #3182ce;
  border: 1rpx solid #bee3f8;
}

.type-enterprise {
  background: #e6fffa;
  color: #319795;
  border: 1rpx solid #b2f5ea;
}

.task-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #2d3748;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.status-tag.pending {
  background: #fffaf0;
  color: #dd6b20;
  border: 1rpx solid #fbd38d;
}

.status-tag.processed {
  background: #f0fff4;
  color: #38a169;
  border: 1rpx solid #c6f6d5;
}

.card-body {
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  margin-bottom: 8rpx;
  font-size: 26rpx;
}

.label {
  color: #718096;
  width: 160rpx;
}

.value {
  color: #4a5568;
  flex: 1;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx dashed #edf2f7;
}

.detail-hint {
  font-size: 24rpx;
  color: #3182ce;
}

.arrow {
  font-size: 28rpx;
  color: #3182ce;
}
