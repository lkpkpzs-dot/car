.detail-container {
  min-height: 100vh;
  background-color: #f7fafc;
  padding: 30rpx 30rpx 150rpx;
}

.section-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a365d;
  margin-bottom: 30rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #3182ce;
}

.info-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  font-size: 28rpx;
}

.label {
  color: #718096;
  width: 160rpx;
}

.value {
  color: #2d3748;
  flex: 1;
  text-align: right;
}

.value.highlight {
  font-weight: bold;
  color: #1a365d;
}

/* Timeline Styles */
.timeline {
  padding-left: 20rpx;
}

.timeline-item {
  position: relative;
  padding-bottom: 40rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-line {
  position: absolute;
  left: 0;
  top: 10rpx;
  bottom: 0;
  width: 2rpx;
  background-color: #e2e8f0;
}

.timeline-item:last-child .timeline-line {
  display: none;
}

.timeline-dot {
  position: absolute;
  left: -9rpx;
  top: 10rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #cbd5e0;
  border: 4rpx solid white;
  z-index: 1;
}

.timeline-dot.active {
  background-color: #3182ce;
  box-shadow: 0 0 10rpx rgba(49, 130, 206, 0.5);
}

.timeline-content {
  padding-left: 40rpx;
}

.timeline-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.node-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #2d3748;
}

.time {
  font-size: 22rpx;
  color: #a0aec0;
}

.reviewer-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #718096;
  margin-bottom: 16rpx;
}

.action-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  background: #edf2f7;
  color: #4a5568;
}

.comment-box {
  background: #f8fafc;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.comment-label {
  color: #718096;
}

.comment-text {
  color: #4a5568;
}

/* Footer Actions */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 30rpx 40rpx calc(30rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.reject-btn {
  background-color: #fff5f5;
  color: #e53e3e;
  border: 2rpx solid #feb2b2;
}

.approve-btn {
  background-color: #1a365d;
  color: white;
}

/* Modal Styles */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  width: 85%;
  border-radius: 32rpx;
  overflow: hidden;
  animation: modalIn 0.3s ease-out;
}

@keyframes modalIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

.modal-header {
  padding: 40rpx 40rpx 20rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #1a365d;
}

.modal-body {
  padding: 20rpx 40rpx 40rpx;
}

.reason-textarea {
  width: 100%;
  height: 200rpx;
  background: #f7fafc;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.modal-footer {
  display: flex;
  padding: 0 40rpx 40rpx;
  gap: 20rpx;
}

.m-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.cancel {
  background: #f7fafc;
  color: #718096;
}

.confirm-pass {
  background: #1a365d;
  color: white;
}

.confirm-reject {
  background: #e53e3e;
  color: white;
}

.empty-history {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #a0aec0;
}

.read-only-tip {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx 40rpx calc(30rpx + env(safe-area-inset-bottom));
  background: #edf2f7;
  text-align: center;
  font-size: 26rpx;
  color: #718096;
}
