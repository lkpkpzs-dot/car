.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  padding-bottom: 60rpx;
}

.header {
  background: linear-gradient(135deg, #1a365d 0%, #2d5a87 50%, #3b82f6 100%);
  padding: 48rpx 32rpx 64rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  opacity: 0.85;
  position: relative;
  z-index: 1;
}

.tabs {
  display: flex;
  background-color: #fff;
  padding: 12rpx 24rpx;
  margin: -20rpx 24rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
  position: relative;
  z-index: 2;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #64748b;
  position: relative;
  transition: all 0.3s ease;
  font-weight: 500;
}

.tab.active {
  color: #1a365d;
  font-weight: 700;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #1a365d 0%, #3b82f6 100%);
  border-radius: 3rpx;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #94a3b8;
  font-size: 28rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: #3b82f6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.user-list {
  padding: 20rpx 24rpx;
}

.user-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
  border: 2rpx solid rgba(241, 245, 249, 0.8);
  transition: all 0.3s ease;
}

.user-card:active {
  transform: scale(0.995);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 10rpx;
}

.user-phone {
  display: block;
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 6rpx;
}

.user-id {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
}

.status-badge {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.status-normal {
  background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
  color: #16a34a;
}

.status-banned {
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
  color: #dc2626;
}

.stats-grid {
  display: flex;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 20rpx;
  padding: 28rpx 0;
  margin-bottom: 28rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-item.invalid .stat-value {
  color: #dc2626;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #1a365d;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 2rpx solid #f1f5f9;
}

.ban-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.ban-label {
  font-size: 24rpx;
  color: #64748b;
}

.ban-time {
  font-size: 24rpx;
  color: #dc2626;
  font-weight: 600;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 20rpx 36rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  border: none;
  line-height: 1.2;
  font-weight: 600;
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.96);
}

.btn-ban {
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
  color: #dc2626;
  box-shadow: 0 4rpx 12rpx rgba(220, 38, 38, 0.15);
}

.btn-unban {
  background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
  color: #16a34a;
  box-shadow: 0 4rpx 12rpx rgba(22, 163, 74, 0.15);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 140rpx 0;
}

.empty-image {
  width: 220rpx;
  height: 220rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #94a3b8;
}
