.detail-container {
  min-height: 100vh;
  background: #f7fafc;
  padding: 30rpx 30rpx 170rpx;
}

.section-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a365d;
  margin-bottom: 28rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #3182ce;
}

.info-item {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 15rpx 0;
  font-size: 27rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  width: 190rpx;
  color: #718096;
  flex-shrink: 0;
}

.value {
  flex: 1;
  text-align: right;
  color: #2d3748;
  word-break: break-all;
}

.highlight {
  font-weight: 700;
  color: #1a365d;
}

.condition-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
  color: #4a5568;
  font-size: 26rpx;
  border-bottom: 1rpx solid #edf2f7;
}

.condition-row text:first-child {
  flex: 1;
}

.condition-row text:last-child {
  color: #1a365d;
  font-weight: 700;
}

.material-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.material-label {
  display: block;
  font-size: 24rpx;
  color: #4a5568;
  margin-bottom: 10rpx;
}

.material-img {
  width: 100%;
  height: 180rpx;
  border-radius: 12rpx;
  background: #f8fafc;
}

.empty-line {
  text-align: center;
  padding: 32rpx 0;
  color: #a0aec0;
  font-size: 26rpx;
}

.penalty-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.penalty-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a365d;
  margin-bottom: 12rpx;
}

.penalty-line {
  color: #718096;
  font-size: 25rpx;
  line-height: 1.7;
}

.footer-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 18rpx;
  padding: 24rpx 30rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.penalty-btn {
  color: #1a365d;
  background: #ebf8ff;
  border: 1rpx solid #bee3f8;
}

.reject-btn {
  color: #dc2626;
  background: #fff5f5;
  border: 1rpx solid #fecaca;
}

.approve-btn {
  color: #fff;
  background: #1a365d;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  background: #fff;
  border-radius: 28rpx;
  overflow: hidden;
}

.modal-header {
  text-align: center;
  padding: 38rpx 40rpx 20rpx;
  color: #1a365d;
  font-size: 34rpx;
  font-weight: 700;
}

.modal-body {
  padding: 20rpx 40rpx 36rpx;
}

.reason-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #f7fafc;
  font-size: 28rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 0 40rpx 40rpx;
}

.m-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.cancel {
  background: #f7fafc;
  color: #718096;
}

.confirm-reject {
  background: #e53e3e;
  color: #fff;
}
