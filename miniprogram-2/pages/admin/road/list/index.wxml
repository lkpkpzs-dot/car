<view class="container">
  <!-- Tab 切换 -->
  <view class="tab-header">
    <view 
      wx:for="{{tabs}}" 
      wx:key="*this" 
      class="tab-item {{activeTab === index ? 'active' : ''}}" 
      bindtap="onTabChange" 
      data-index="{{index}}"
    >
      {{item}}
      <view class="tab-line" wx:if="{{activeTab === index}}"></view>
    </view>
  </view>

  <view class="list-content">
    <view class="empty-state" wx:if="{{displayList.length === 0 && !loading}}">
      <image src="/assets/images/empty.png" mode="aspectFit" />
      <text>暂无相关申请记录</text>
    </view>

    <view class="audit-card card" wx:for="{{displayList}}" wx:key="id" bindtap="onDetail" data-item="{{item}}">
      <view class="card-header">
        <text class="enterprise-name">{{item.enterpriseName || '未知企业'}}</text>
        <view class="status-tags">
          <view class="status-tag {{item.statusClass}}">{{item.statusLabel}}</view>
          <view class="status-tag {{item.inspectionStatusClass}}" wx:if="{{item.status === 2}}">{{item.inspectionStatusLabel}}</view>
          <view class="status-tag {{item.plateStatusClass}}" wx:if="{{item.status === 2 && item.inspectionStatus === 2}}">{{item.plateStatusLabel}}</view>
        </view>
      </view>
      
      <view class="card-body">
        <view class="info-row">
          <text class="label">申请类型</text>
          <text class="value">{{item.typeLabel}}</text>
        </view>
        <view class="info-row">
          <text class="label">车辆品牌</text>
          <text class="value">{{item.vehicleBrand}}</text>
        </view>
        <view class="info-row">
          <text class="label">VIN码</text>
          <text class="value">{{item.vin}}</text>
        </view>
        <view class="info-row">
          <text class="label">申请时间</text>
          <text class="value">{{item.createTimeShort}}</text>
        </view>
      </view>
      
      <view class="card-footer">
        <text class="detail-link">{{activeTab === 0 ? '点击审核' : '查看详情'}}</text>
        <view class="action-buttons">
          <button 
            wx:if="{{item.status === 2 && item.inspectionStatus !== 2}}" 
            class="btn-inspect {{item.inspectionStatus === 3 ? 'btn-inspect-retry' : ''}}"
            catchtap="onInspect" 
            data-item="{{item}}"
          >{{item.inspectionStatus === 3 ? '重新查验' : '查验'}}</button>
          <button 
            wx:if="{{item.status === 2 && item.inspectionStatus === 2 && item.plateStatus !== 1}}" 
            class="btn-issue-plate"
            catchtap="onIssuePlate" 
            data-item="{{item}}"
          >发牌</button>
        </view>
        <view class="arrow-icon"></view>
      </view>
    </view>
  </view>
</view>
