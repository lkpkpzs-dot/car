page {
  background: linear-gradient(135deg, #1a365d 0%, #2c5282 100%);
  min-height: 100vh;
}

.scan-container {
  min-height: 100vh;
}

.header-section {
  padding: 60rpx 30rpx 40rpx;
  text-align: center;
  color: white;
}

.header-title {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.scan-section {
  padding: 0 30rpx;
}

.scan-card {
  background: white;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.scan-icon-container {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scan-icon {
  width: 160rpx;
  height: 160rpx;
  z-index: 1;
}

.scan-ring {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border: 4rpx solid #3182ce;
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.1);
    opacity: 0.5;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.scan-text {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1a365d;
  margin-bottom: 20rpx;
}

.scan-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.result-section {
  padding: 0 30rpx;
}

.result-card {
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.result-header {
  padding: 40rpx;
  text-align: center;
}

.result-status {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-status.valid {
  color: #38a169;
}

.result-status.invalid {
  color: #e53e3e;
}

.status-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
}

.result-body {
  padding: 0 40rpx 40rpx;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.item-label {
  font-size: 28rpx;
  color: #999;
}

.item-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  text-align: right;
  flex: 1;
  margin-left: 20rpx;
}

.result-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx 40rpx;
  background: #f9fafb;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

.primary-btn {
  background: linear-gradient(135deg, #3182ce 0%, #2c5282 100%);
  color: white;
}

.secondary-btn {
  background: white;
  color: #3182ce;
  border: 2rpx solid #3182ce;
}

.btn-text {
  color: inherit;
  font-weight: bold;
}

.tips-section {
  padding: 30rpx;
  margin-top: auto;
}

.tips-card {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 30rpx;
  backdrop-filter: blur(10px);
}

.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 20rpx;
}

.tips-content {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 10rpx;
  line-height: 1.6;
}
