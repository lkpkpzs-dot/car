.settings-container {
  min-height: 100vh;
  background: #f0f4f8;
  padding: 0;
}

.header-section {
  background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 50%, #3b82f6 100%);
  padding: 60rpx 32rpx 80rpx;
  color: white;
  position: relative;
  overflow: hidden;
}

.header-section::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -120rpx;
  width: 360rpx;
  height: 360rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.12) 0%, transparent 70%);
  border-radius: 50%;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
  position: relative;
  z-index: 1;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
  position: relative;
  z-index: 1;
}

.form-card {
  background: #fff;
  margin: -40rpx 24rpx 0;
  border-radius: 28rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(15, 23, 42, 0.06);
  position: relative;
  z-index: 10;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 20rpx;
}

.form-input {
  width: 100%;
  height: 96rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #1e293b;
  box-sizing: border-box;
  transition: all 0.2s;
}

.form-input:focus {
  background: #fff;
  border-color: #3b82f6;
}

.input-placeholder {
  color: #94a3b8;
}

.save-btn {
  margin: 48rpx 24rpx 0;
  background: linear-gradient(135deg, #3b82f6, #1e40af);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  height: 96rpx;
  line-height: 96rpx;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.25);
  transition: all 0.2s;
}

.save-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.2);
}

.save-btn[disabled] {
  opacity: 0.6;
}
