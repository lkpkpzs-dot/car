page {
  background: linear-gradient(135deg, #0d1b2a 0%, #1b263b 100%);
  height: 100vh;
  overflow: hidden;
}

.splash-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0 100rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 1.2s ease-out;
}

.logo-section.fade-in {
  opacity: 1;
  transform: translateY(0);
}

.logo {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 40rpx;
  filter: drop-shadow(0 0 20rpx rgba(255, 255, 255, 0.2));
}

.app-title {
  font-size: 64rpx;
  font-weight: bold;
  color: white;
  letter-spacing: 12rpx;
  margin-bottom: 16rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 4rpx;
}

.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0;
  transition: opacity 0.8s ease-in;
}

.loading-section.fade-in {
  opacity: 1;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
  margin-bottom: 30rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #38b2ac;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1.0); }
}

.loading-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.footer-section {
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
  letter-spacing: 2rpx;
}
